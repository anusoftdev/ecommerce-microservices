<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="appName"
                    source="spring.application.name"/>

    <!-- JSON appender — for production / log aggregation -->
    <appender name="JSON_CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Add service name to every log line -->
            <customFields>{"service":"${appName}"}</customFields>
            <!-- Include traceId and spanId from Micrometer -->
            <provider class="net.logstash.logback.composite.loggingevent.LoggingEventPatternJsonProvider">
                <pattern>
                    {
                    "traceId": "%X{traceId}",
                    "spanId": "%X{spanId}"
                    }
                </pattern>
            </provider>
        </encoder>
    </appender>

    <!-- Plain text appender — readable during local dev -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{HH:mm:ss.SSS} [%thread] [%X{traceId}/%X{spanId}] %-5level %logger{36} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- Use JSON in prod profile, plain text locally -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.ecommerce" level="DEBUG"/>
    </springProfile>

</configuration>